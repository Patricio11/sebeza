# Sebenza environment  copy to `.env.local` and fill the keys for the phase you're working on.
# `.env.local` is gitignored by Next.js. NEVER commit real credentials to this file (.env.example).

# ─────────────────────────────────────────────────────────────────────────────
# Phase 0 / 1 / 1.5  already running on mock data, nothing needed
# ─────────────────────────────────────────────────────────────────────────────

# Data provider seam. Phase 23.5: "db" is the DEFAULT (and the only value
# allowed in production  "mock" throws there). "mock" is an explicit dev/test
# escape hatch for off-DB demos only.
SEBENZA_DATA_PROVIDER=db


# ─────────────────────────────────────────────────────────────────────────────
# Phase 2  Auth + real consent persistence
# ─────────────────────────────────────────────────────────────────────────────

# Neon Postgres (eu-central-1 recommended; document the cross-border note before real PII).
# Run `npm run db:generate && npm run db:migrate && npm run db:seed` once this is set.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# AES-256 base64 key for field-level encryption of national IDs.
# Generate locally:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SEBENZA_ENCRYPTION_KEY=

# Better Auth  generate the secret the same way as SEBENZA_ENCRYPTION_KEY.
# BETTER_AUTH_URL is the base URL the auth handler runs at (no trailing slash).
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Phase 9.17  HMAC-SHA256 signing key for employer-initiated seeker
# invitation tokens. Kept separate from BETTER_AUTH_SECRET so a leak
# of one signing key doesn't compromise the other token kind. Same
# format as the keys above; any long passphrase works.
SEBENZA_INVITE_SIGNING_SECRET=

# Email transport  SMTP-only via nodemailer (lib/email/send.ts).
#   - smtp    : real send through any SMTP provider (Mailtrap sandbox
#                for dev; Resend / Sendgrid / Postmark / AWS SES SMTP
#                relay for prod). Provider swap = env-var change only.
#   - console : fallback that logs to terminal; no credentials needed.
EMAIL_TRANSPORT=console

# Generic SMTP credentials. Same shape for every provider:
#   Mailtrap sandbox (dev):
#     SMTP_HOST=sandbox.smtp.mailtrap.io  SMTP_PORT=2525  SMTP_SECURE=false
#     SMTP_USER + SMTP_PASS come from the Mailtrap inbox UI.
#   Resend SMTP relay (prod):
#     SMTP_HOST=smtp.resend.com  SMTP_PORT=587  SMTP_SECURE=false
#     SMTP_USER=resend  SMTP_PASS=<your Resend API key (re_...)>
#   Sendgrid: SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587 SMTP_USER=apikey ...
#   AWS SES: SMTP_HOST=email-smtp.<region>.amazonaws.com  SMTP_PORT=587 ...
#
# SMTP_SECURE=true only when the provider uses TLS-on-connect (port 465
# convention). Most modern providers run STARTTLS on 587  set false.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sebenzasa.com
SMTP_FROM_NAME=Sebenza


# ─────────────────────────────────────────────────────────────────────────────
# Phase 3  File storage (CVs, certificates, profile photos)
# ─────────────────────────────────────────────────────────────────────────────

# Supabase Storage (used standalone  auth is still Better Auth, DB is still Neon).
# Create a Supabase project, then a PRIVATE bucket (e.g. "sebenza-private").
# The service-role key NEVER touches the client  it lives on the server only.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=sebenza-private



# ─────────────────────────────────────────────────────────────────────────────
# Phase 9  Rate limiting + brute-force protection
# ─────────────────────────────────────────────────────────────────────────────

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ─────────────────────────────────────────────────────────────────────────────
# Phase 10  Observability (optional during Phase 2; required pre-launch)
# ─────────────────────────────────────────────────────────────────────────────

# Sentry  privacy-respecting analytics, PII scrubbed.
SENTRY_DSN=


# ─────────────────────────────────────────────────────────────────────────────
# Phases 8–26  crons, channels, KYC (added 2026-07-06; audit gap-fill)
# ─────────────────────────────────────────────────────────────────────────────

# Shared secret for ALL /api/cron/* routes (20 jobs in vercel.json). Routes
# fail CLOSED (503) when unset. Vercel Cron sends it as `Authorization: Bearer`.
CRON_SECRET=

# DB driver seam (Phase 12 / AWS runbook): "neon" (default, serverless) or
# "postgres-js" (local Docker / EC2 Postgres).
# DATABASE_DRIVER=postgres-js

# Email hardening (Phase 9.18): fail loud when EMAIL_TRANSPORT is missing but
# SMTP_* vars are present (defaults to loud in production).
# EMAIL_TRANSPORT_STRICT=true
# Legacy from-address fallback (prefer SMTP_FROM):
# EMAIL_FROM=

# SMS channel (Phase 11.4.4, dormant; Phase 25 lets admins manage these
# credentials ENCRYPTED in the DB from /admin/integrations instead  the env
# vars remain the fallback): twilio | sns | console
# SMS_PROVIDER=
# SMS_FROM_NUMBER=+27...
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# SNS_AWS_REGION=af-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# WhatsApp channel (Phase 11.4.4, dormant; admin-manageable per above):
# WHATSAPP_PROVIDER=
# WHATSAPP_FROM_NUMBER=

# KYC adapter selector (Phase 8, dormant behind feature_flag_kyc_provider):
# KYC_PROVIDER=mock

# Absolute origin used in employment-verification email links (Phase 9.23):
# NEXT_PUBLIC_APP_ORIGIN=https://sebenzasa.com
